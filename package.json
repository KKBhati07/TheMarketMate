{
  "name": "marketmate",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "nx serve",
    "build": "nx build",
    "watch": "nx build --watch --configuration development",
    "test": "nx test",
    "serve:ssr:marketmate": "node dist/marketmate/server/server.mjs",
    "analyze:marketmate": "nx build marketmate --configuration production --source-map && source-map-explorer \"dist/marketmate/browser/*.js\"",
    "analyze:marketmate:dev": "nx build marketmate --configuration development --source-map && source-map-explorer \"dist/marketmate/browser/*.js\"",
    "analyze:admin": "nx build mm-admin-portal --configuration production --source-map && source-map-explorer \"dist/mm-admin-portal/browser/*.js\"",
    "analyze:all": "npm run analyze:marketmate && npm run analyze:admin"
  },
  "dependencies": {
    "@angular/animations": "21.1.2",
    "@angular/common": "21.1.2",
    "@angular/compiler": "21.1.2",
    "@angular/core": "21.1.2",
    "@angular/forms": "21.1.2",
    "@angular/material": "21.1.2",
    "@angular/platform-browser": "21.1.2",
    "@angular/platform-browser-dynamic": "21.1.2",
    "@angular/platform-server": "21.1.2",
    "@angular/router": "21.1.2",
    "@angular/ssr": "21.1.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ngx-cookie-service": "21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.1.2",
    "@angular-devkit/core": "21.1.2",
    "@angular-devkit/schematics": "21.1.2",
    "@angular/cli": "21.1.2",
    "@angular/compiler-cli": "21.1.2",
    "@nx/angular": "22.4.4",
    "@nx/eslint": "22.4.4",
    "@nx/workspace": "22.4.4",
    "@schematics/angular": "21.1.2",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.6",
    "@types/express": "^4.17.17",
    "@types/node": "^24.10.9",
    "ng-packagr": "21.1.0",
    "nx": "22.4.4",
    "source-map-explorer": "^2.5.3",
    "typescript": "~5.9.3"
  }
}
