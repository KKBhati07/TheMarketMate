# Dockerfile.prod
FROM node:20-slim

WORKDIR /app

# Copy package files first
COPY package*.json ./
RUN npm install

# Copy source
COPY . .

# Build Angular SSR app
RUN npx nx build marketmate

# Expose HTTPS port
EXPOSE 4000

# Start real SSR server
CMD ["node", "dist/marketmate/server/server.mjs"]
